# ---- Hyperliquid ----
# The MAIN account address (0x...) that holds the funds / approved the API wallet.
HL_ACCOUNT_ADDRESS=0xYOUR_MAIN_ACCOUNT_ADDRESS
# The API / agent wallet PRIVATE KEY (0x...). Agent wallets can trade but NOT withdraw.
# Generate one at https://app.hyperliquid.xyz/API and approve it for your account.
HL_SECRET_KEY=0xYOUR_API_WALLET_PRIVATE_KEY
# mainnet | testnet  (trade.xyz `xyz` markets are mainnet)
HL_NETWORK=mainnet

# ---- Tree of Alpha (news feed) ----
# Get it from https://news.treeofalpha.com/account  (or DM "Managey Boi" -> "api" in Tree Discord)
TREE_API_KEY=your_tree_api_key

# ---- Anthropic (NLP / Claude) ----
ANTHROPIC_API_KEY=sk-ant-your_key

# ---- Telegram alerts (bot that messages YOU) ----
# Create a bot with @BotFather, then get the chat/channel id (e.g. via @userinfobot or getUpdates).
TELEGRAM_BOT_TOKEN=123456:ABC-your_bot_token
TELEGRAM_CHAT_ID=-1001234567890

# ---- Telegram source ingestion (reads news channels via your user account) ----
# Get api_id + api_hash from https://my.telegram.org (API development tools).
# Then run: python scripts/telegram_login.py   (one-time phone login -> creates data/tg_session)
# Set the channels to monitor in config.yaml -> telegram_channels.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ---- Arena LLM providers (optional — only needed for `python -m hlbot.main_arena`) ----
# Each is only required if a config.yaml arena entrant routes to that provider.
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
ZHIPU_API_KEY=

# ---- Arena per-model wallets (optional; LIVE arena lanes only) ----
# A lane trades real money only when BOTH config.yaml sets live:true AND its wallet
# is set here. Unfunded/absent = that lane paper-trades on virtual capital.
# One pair per entrant `wallet` key: ARENA_<KEY>_ADDRESS / ARENA_<KEY>_SECRET, e.g.:
# ARENA_SONNET_ADDRESS=
# ARENA_SONNET_SECRET=

# ---- Historical data for scripts/earnings_bench.py (optional) ----
TWELVEDATA_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=
